FROM node:20-alpine

# Install pnpm
RUN npm install -g pnpm

WORKDIR /app

# Copy root workspace files
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml* ./
COPY backend/package.json ./backend/

# Install dependencies
RUN pnpm install --filter backend

WORKDIR /app/backend

EXPOSE 3000

CMD ["pnpm", "start:dev"]
